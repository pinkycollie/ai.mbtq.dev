{
  "name": "mbtq-ai-platform",
  "version": "2.0.0",
  "description": "Full Generative AI Development Platform with Sign Language capabilities, Deaf-centric accessibility, and containerized deployment (Agnostic Backend)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "test": "mocha tests/**/*.test.ts",
    "lint": "eslint . --ext .ts",
    "type-check": "tsc --noEmit",
    "db:setup": "node scripts/setup-db.mjs",
    "cli": "node cli/launcher.mjs",
    "docker:build": "docker build -t mbtq-ai-platform .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down"
  },
  "dependencies": {
    "@ai-sdk/groq": "latest",
    "@neondatabase/serverless": "latest",
    "bcryptjs": "latest",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "nodemailer": "latest",
    "rss-parser": "^3.13.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/supertest": "^7.2.0",
    "chai": "^6.2.2",
    "eslint": "^8.0.0",
    "mocha": "^11.7.5",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "generative-ai",
    "sign-language",
    "accessibility",
    "deaf-community",
    "asl-translation",
    "bsl-translation",
    "machine-learning",
    "docker",
    "microservices",
    "typescript",
    "backend",
    "generative-platform"
  ],
  "author": "Pinky <pinky@signlanguageai.com>",
  "license": "MIT",
  "mocha": {
    "node-option": [
      "import=tsx"
    ]
  }
}
